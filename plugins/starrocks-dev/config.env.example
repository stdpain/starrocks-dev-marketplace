# starrocks-dev configuration TEMPLATE.
#
# Copy this to ~/.config/starrocks_dev/config.env and fill in YOUR values:
#     mkdir -p ~/.config/starrocks_dev
#     cp config.env.example ~/.config/starrocks_dev/config.env
#     chmod 600 ~/.config/starrocks_dev/config.env
#
# This file is a public template — keep real hosts, registry addresses, internal
# paths, and credentials OUT of it. They belong only in your private config.env
# (which lives under ~/.config and is never committed).
#
# PARALLEL WORK (profiles): to build/deploy several features at once, give each its
# own profile. `SR_PROFILE=<name>` makes every skill read
# ~/.config/starrocks_dev/profiles/<name>/config.env instead of this default file —
# its own container, source worktree, deploy dir and (auto-allocated) ports. Create
# one with: bash skills/sr-connect/scripts/workspace.sh create <name> --branch <b>.
# SR_PROFILE is NOT a key in this file; it is passed in the environment per command.

# --- SSH connection ---
SR_HOST=                    # hostname/IP or a ~/.ssh/config alias of your dev box
SR_USER=                    # ssh user (omit if the alias already sets it)
SR_PORT=22
SR_KEY=                     # optional identity file, e.g. ~/.ssh/id_ed25519
SR_PROXY_JUMP=              # optional bastion/jump host: user@jump[:port] (or 'j1,j2' to chain)

# --- Source location ---
SR_SRC=/root/starrocks      # source path the BUILD uses (inside the container when SR_DOCKER is set)

# --- Docker dev-env (set these to compile inside a container) ---
SR_DOCKER=                  # container name, e.g. sr-dev-main
SR_IMAGE=                   # dev-env image, e.g. <your-registry>/starrocks/dev-env-ubuntu:latest
SR_HOST_SRC=                # source path on the HOST mounted to SR_SRC; default: remote $HOME/basename(SR_SRC)
SR_NOFILE=655350            # ulimit nofile for the container
SR_M2=                      # optional host ~/.m2 to mount as /root/.m2
SR_CCACHE=                  # optional host dir for the shared C++ ccache, e.g. $HOME/.ccache
                            #   mounted as /root/.ccache, namespaced per dev-env image so all
                            #   profiles on the same toolchain share one warm cache. Set this
                            #   once here and every profile inherits it.
SR_CCACHE_SIZE=80G          # ccache max_size cap, per dev-env image (default 80G)
SR_MOLD=                    # optional host path to a PREBUILT mold install (dir with bin/mold).
                            #   Mounted read-only at /opt/mold; BE builds then link with mold
                            #   (STARROCKS_LINKER=mold) instead of gold — much faster link times.
SR_DOCKER_RUN_OPTS=         # extra docker-run opts, e.g. '--network host'

# --- Build / test ---
SR_THIRDPARTY=              # optional STARROCKS_THIRDPARTY override (usually preset in the dev-env image)
SR_JOBS=                    # build parallelism (default: remote nproc)
SR_BUILD_TYPE=Release       # Release | Debug | Asan

# --- Backport (sr-backport) ---
# Template for the dev-env image used when backporting to a release branch, so a
# branch-4.1 backport verifies on the 4.1 image (not main's). Placeholders:
#   {base}   = SR_IMAGE with its tag stripped (e.g. <registry>/starrocks/dev-env-ubuntu)
#   {branch} = full target branch name        (e.g. branch-4.1)
#   {ver}    = numeric version                (e.g. 4.1)
# Default (unset) = '{base}:{branch}'  -> <registry>/starrocks/dev-env-ubuntu:branch-4.1
# Use '{base}:{ver}' or '{base}:{ver}-latest' if your registry tags images that way.
# 'main'/'master' always reuse SR_IMAGE unchanged. Override per-run with `prepare --image`.
SR_BP_IMAGE_TPL=

# --- Deploy ---
# Where the cluster RUNS. If set, build artifacts are synced here and FE/BE run
# from it, so meta/storage survive a rebuild. If unset, runs in-place from output/.
SR_DEPLOY_DIR=             # e.g. $HOME/sr-run   (leave empty to run in-place)

# Run the cluster in the dev-env container (1, default when SR_DOCKER is set) or
# directly on the HOST (0) while still building in the container. Host run keeps
# the cluster alive across container rebuilds and binds the host's real NIC.
SR_DEPLOY_IN_DOCKER=       # 0 = run on host, 1 = run in container (default if SR_DOCKER set)

SR_MYSQL_HOST=127.0.0.1    # FE host as seen from where mysql runs
# BE registration address. Leave EMPTY to auto-use the remote `hostname -i` — the
# IP the BE detects for itself. 127.0.0.1 fails on multi-NIC/docker hosts (the FE
# heartbeat is rejected: "not equal to backend localhost <ip>") so don't hardcode it.
SR_BE_HOST=                # empty => remote `hostname -i`; override only if you must
# CIDR for multi-NIC hosts, e.g. 10.0.0.0/24. Leave EMPTY to auto-detect: on a host
# with >1 NIC (e.g. real NIC + docker0) deploy pins FE+BE to the real NIC so they
# don't split across interfaces. Set explicitly only to force a specific NIC.
SR_PRIORITY_NET=           # empty => auto on multi-NIC hosts

# Shared/mixed-use box? Leave SR_AUTO_PORTS=1 (default): the ports below are used
# as STARTING points and each is bumped to the next free port on the remote, then
# pinned to <run-dir>/.sr-ports.env so restarts stay stable. Set 0 to force the
# exact ports below. Reallocate later with: bash scripts/deploy.sh ports
SR_AUTO_PORTS=1

# Cluster ports (StarRocks defaults). With auto-ports on these are just the search
# start; with it off they are used as-is.
SR_QUERY_PORT=9030         # FE MySQL protocol
SR_HTTP_PORT=8030          # FE http
SR_RPC_PORT=9020           # FE thrift rpc
SR_EDIT_LOG_PORT=9010      # FE bdbje edit log
SR_BE_PORT=9060            # BE thrift
SR_BE_HTTP_PORT=8040       # BE http
SR_BE_HEARTBEAT=9050       # BE heartbeat
SR_BE_BRPC_PORT=8060       # BE brpc

# --- Benchmark / test clusters (sr-bench) ---
# Benchmark clusters are NOT configured in this file. They are a named registry under
# ~/.config/starrocks_dev/bench/<name>.env (topology + credential VAR NAMES only — no
# secrets), managed with: bash skills/sr-bench/scripts/bench.sh add <name> --fe <host> ...
# The shared account+password those clusters log in with is read from the ENVIRONMENT at
# run time and is NEVER stored. Export it in your shell (do NOT put it here):
#     export SR_BENCH_USER=root
#     export SR_BENCH_PASS=...        # used for the MySQL FE and node SSH
# A cluster entry can point at different var names (--user-var/--pass-var) if needed.
